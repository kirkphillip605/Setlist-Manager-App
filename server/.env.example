# ─── Server Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.

# ── Core ──────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/setlistpro
FRONTEND_URL=https://setlist.kirknet.io
BETTER_AUTH_URL=https://api.setlist.kirknet.io
BETTER_AUTH_SECRET=generate-a-long-random-secret-here

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email (Mailjet) ──────────────────────────────────────────────
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key
MAILJET_FROM_EMAIL=noreply@setlist.kirknet.io
MAILJET_FROM_NAME=SetlistPRO

# ── SMS (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ── Session ───────────────────────────────────────────────────────
# Sessions persist for this many days (default: 365)
SESSION_MAX_AGE_DAYS=365
# Session token is refreshed if older than this many hours (default: 24)
SESSION_UPDATE_AGE_HOURS=24

# ── Auth Behavior ─────────────────────────────────────────────────
# Require email verification before allowing login (default: false)
REQUIRE_EMAIL_VERIFICATION=false
# Minimum password length (default: 8)
MIN_PASSWORD_LENGTH=8

# ── OTP / Magic Link ─────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=600
MAGIC_LINK_EXPIRY_SECONDS=600

# ── Cookies (for cross-subdomain auth) ───────────────────────────
# Set this if frontend and API share a parent domain (e.g. .kirknet.io)
# COOKIE_DOMAIN=.kirknet.io

# ── Additional Trusted Origins (comma-separated) ─────────────────
# ADDITIONAL_TRUSTED_ORIGINS=https://staging.setlist.kirknet.io

# ── Deep Linking / Native Apps ────────────────────────────────────
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
ANDROID_CERT_FINGERPRINT=YOUR_SHA256_FINGERPRINT

# ── External APIs ────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
