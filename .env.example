# ─── Frontend Environment Variables ───────────────────────────────
# All VITE_ prefixed vars are exposed to the browser at build time.

# API base URL (Hono backend)
VITE_API_URL=https://api.setlist.kirknet.io

# Spotify integration (for song lookup)
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id

# Sentry error tracking
VITE_SENTRY_DSN=your-sentry-dsn

# App store URLs (shown in update prompts)
VITE_APPLE_APP_STORE_URL=https://apps.apple.com/app/setlistpro/id000000000
VITE_GOOGLE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kirknetllc.setlistpro
